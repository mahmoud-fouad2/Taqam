{
  "name": "taqam",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:lan": "next dev --webpack --hostname 0.0.0.0",
    "build": "prisma generate && node scripts/run-next-build.mjs",
    "build:render": "prisma generate && next build",
    "build:webpack": "prisma generate && next build --webpack",
    "analyze": "set ANALYZE=true&& next build --webpack",
    "start": "node scripts/start-production.mjs",
    "start:render": "node scripts/render-start.mjs",
    "typecheck": "pnpm exec next typegen && tsc --noEmit",
    "typecheck:mobile": "pnpm --dir apps/mobile typecheck",
    "lint": "eslint app components hooks i18n lib prisma scripts types proxy.ts capacitor.config.ts next.config.ts prisma.config.ts sentry.edge.config.ts sentry.server.config.ts instrumentation.ts instrumentation-client.ts vitest.config.ts eslint.config.mjs postcss.config.mjs",
    "lint:strict": "eslint --max-warnings=0 app components hooks i18n lib prisma scripts types proxy.ts capacitor.config.ts next.config.ts prisma.config.ts sentry.edge.config.ts sentry.server.config.ts instrumentation.ts instrumentation-client.ts vitest.config.ts eslint.config.mjs postcss.config.mjs",
    "format": "prettier . --write --ignore-path .prettierignore",
    "format:all": "pnpm format && pnpm format:mobile",
    "format:check": "prettier . --check --ignore-path .prettierignore",
    "format:check:all": "pnpm format:check && pnpm format:check:mobile",
    "format:mobile": "prettier apps/mobile/package.json apps/mobile/app.json \"apps/mobile/{app,components,constants,hooks,lib,scripts,theme}/**/*.{ts,tsx,js,jsx,json,md}\" --write --ignore-unknown",
    "format:check:mobile": "prettier apps/mobile/package.json apps/mobile/app.json \"apps/mobile/{app,components,constants,hooks,lib,scripts,theme}/**/*.{ts,tsx,js,jsx,json,md}\" --check --ignore-unknown",
    "validate:all": "pnpm format:check:all && pnpm typecheck && pnpm lint:strict && pnpm test && pnpm build && pnpm typecheck:mobile",
    "validate:ci": "pnpm format:check:all && pnpm typecheck && pnpm lint:strict && pnpm test && pnpm build && pnpm typecheck:mobile",
    "cap:sync:android": "cap sync android",
    "android:open": "cap open android",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "android:apk:release": "cd android && gradlew.bat assembleRelease",
    "android:build": "node scripts/build-apk.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@hookform/resolvers": "^3.10.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@sentry/nextjs": "^10.48.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "arabic-persian-reshaper": "^1.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "16.1.0",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "radix-ui": "latest",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.72.1",
    "react-leaflet": "^5.0.0",
    "recharts": "2.15.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}
