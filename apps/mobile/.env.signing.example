# Copy this file to .env.signing.local and fill your real upload keystore values.
# The local file is ignored by git via apps/mobile/.gitignore.

TAQAM_UPLOAD_STORE_FILE="C:/secure/taqam-upload-key.jks"
TAQAM_UPLOAD_STORE_PASSWORD="replace-with-store-password"
TAQAM_UPLOAD_KEY_ALIAS="taqam-upload"
TAQAM_UPLOAD_KEY_PASSWORD="replace-with-key-password"